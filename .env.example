PORT=3000
BACK_HOST_URL=http://localhost:3000

SWAGGER_PASS=admin

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=root

# Must be https unless ALLOW_INSECURE_CLIENT_API=true.
CLIENT_API_URL=https://example.com

PRIVATE_KEY_SECRET=sdaf31232f33fsdf4567890saf32fsd

IP_WHITELIST=127.0.0.1,192.168.1.1,::1

API_KEY_SECRET=sdaf31232f33fsdf4567890saf32fsd

TRON_HOST_URL=https://rpc.ankr.com/premium-http/tron/asdf3fsadf
TRONSAVE_API_URL=https://api.tronsave.io
TRONSAVE_RECEIVER_ADDRESS=TWZEhq5JuUVvGtutNgnRBATbF8BnHGyn4S
TRONSAVE_API_KEY=12f1f-qff-12f1-qfwe-12f1f1

# Comma-separated for failover + quorum: a single endpoint has neither.
ETH_RPC_URL=https://mainnet.infura.io/v3/asdf3fsadf
ETH_WSS_URL=wss://mainnet.infura.io/ws/v3/asdf3fsadf

BASE_RPC_URL=https://rpc.ankr.com/base/asdf3fsadf
BASE_WSS_URL=wss://rpc.ankr.com/base/asdf3fsadf

BSC_RPC_URL=https://rpc.ankr.com/bsc/asdf3fsadf
BSC_WSS_URL=wss://rpc.ankr.com/bsc/asdf3fsadf

POLYGON_RPC_URL=https://rpc.ankr.com/polygon/asdf3fsadf
POLYGON_WSS_URL=wss://rpc.ankr.com/polygon/asdf3fsadf

ARBITRUM_RPC_URL=https://rpc.ankr.com/arbitrum/asdf3fsadf
ARBITRUM_WSS_URL=wss://rpc.ankr.com/arbitrum/asdf3fsadf

OPTIMISM_RPC_URL=https://rpc.ankr.com/optimism/asdf3fsadf
OPTIMISM_WSS_URL=wss://rpc.ankr.com/optimism/asdf3fsadf

AVALANCHE_C_RPC_URL=https://rpc.ankr.com/avalanche-c/asdf3fsadf
AVALANCHE_C_WSS_URL=wss://rpc.ankr.com/avalanche-c/asdf3fsadf

FANTOM_RPC_URL=https://rpc.ankr.com/fantom/asdf3fsadf
FANTOM_WSS_URL=wss://rpc.ankr.com/fantom/asdf3fsadf

BTC_API_URL=https://api.blockcypher.com/v1/btc/main
# --- Deposit confirmation depth (blocks) ---
# The sweep is immediate and irreversible, so these gate acting on a reorg-able deposit.
TRON_CONFIRMATIONS=19
BTC_CONFIRMATIONS=2
ETH_CONFIRMATIONS=12
BASE_CONFIRMATIONS=12
BSC_CONFIRMATIONS=15
POLYGON_CONFIRMATIONS=30
ARBITRUM_CONFIRMATIONS=20
OPTIMISM_CONFIRMATIONS=20
AVALANCHE_C_CONFIRMATIONS=15
FANTOM_CONFIRMATIONS=15

# --- Which EVM networks to monitor (comma-separated) ---
# Each adds an independent WebSocket subscription and reconnect loop to operate.
ENABLED_EVM_NETWORKS=ETH

# --- Client API transport ---
# CLIENT_API_URL must be https unless ALLOW_INSECURE_CLIENT_API=true (development only).
CLIENT_API_KEY=
CLIENT_API_TIMEOUT_MS=10000
# ALLOW_INSECURE_CLIENT_API=true

# --- Key custody ---
# Migration-only escape hatch. While true, wallet rows holding PLAINTEXT private keys are
# accepted and logged at error level. Unset once every key is re-encrypted AND rotated.
# ALLOW_LEGACY_PLAINTEXT_KEYS=true

# --- Automated-outflow limits (decimal strings, empty disables) ---
# A single deposit above this is HELD for manual approval instead of swept.
MAX_AUTO_SWEEP_BTC=
MAX_AUTO_SWEEP_ETH=
MAX_AUTO_SWEEP_TRX=
MAX_AUTO_SWEEP_USDT=
# Rolling one-hour ceiling on total automated outflow per chain+currency.
MAX_HOURLY_SWEEP_BTC=
MAX_HOURLY_SWEEP_ETH=
MAX_HOURLY_SWEEP_TRX=
MAX_HOURLY_SWEEP_USDT=

# --- Scaling ---
# Required before raising PM2 `instances` above 1, so only one instance runs the monitors.
MONITOR_LEADER_ELECTION=false

# --- Schema ---
# Defaults to true only when NODE_ENV=development. Leave unset in production so migrations run.
# TYPEORM_SYNCHRONIZE=false
# Statement-level SQL logging. Parameters are always redacted, but keep this off by default.
# TYPEORM_LOG_QUERIES=false

# --- Misc ---
# swagger.json is a build-time artefact; writing it at boot fails on a read-only filesystem.
# WRITE_SWAGGER_JSON=false
# Redis must run with --maxmemory-policy noeviction; size this to the real working set.
REDIS_MAXMEMORY=3gb
